# ========================================
# ENHANCED SECURITY .HTACCESS CONFIGURATION
# The Vault Gym Website
# ========================================

# 1. DISABLE DIRECTORY BROWSING
Options -Indexes

# 2. ALLOW ACCESS TO ALL HTML FILES (Place this first to ensure access)
<FilesMatch "\.(html|htm|php)$">
    Require all granted
    Order allow,deny
    Allow from all
</FilesMatch>

# 3. ALLOW ACCESS TO IMAGES AND STATIC FILES
<FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|bmp|tiff|css|js|woff|woff2|ttf|eot)$">
    Require all granted
    Order allow,deny
    Allow from all
</FilesMatch>

# 4. PROTECT YOUR CORE CONFIG FILES
<FilesMatch "^(\.htaccess|\.htpasswd|config\.php|php\.ini|error_log|\.env|\.git|\.gitignore|\.DS_Store|Thumbs\.db)$">
    Require all denied
    Order deny,allow
    Deny from all
</FilesMatch>

# 5. BLOCK ACCESS TO SENSITIVE FILE EXTENSIONS
<FilesMatch "\.(log|sql|bak|backup|old|tmp|temp|swp|swo|~)$">
    Require all denied
    Order deny,allow
    Deny from all
</FilesMatch>

# 6. PROTECT AGAINST XSS ATTACKS (Headers)
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# 7. FORCE HTTPS (Uncomment when SSL is configured)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 8. BLOCK MALICIOUS SCRIPT INJECTIONS (Only block clearly malicious patterns)
# Temporarily disabled to allow site access - re-enable after testing
# RewriteEngine On
# RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC]
# RewriteRule ^(.*)$ - [F,L]

# 9. ENABLE GZIP COMPRESSION
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# 10. SET CACHE CONTROL FOR STATIC ASSETS
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# 11. FAVICON — browsers often request /favicon.ico even when HTML declares a PNG
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^favicon\.ico$ images/fav-blk.png [L]
</IfModule>

# 12. SET CUSTOM ERROR PAGES (Optional)
# ErrorDocument 404 /404.html
# ErrorDocument 403 /403.html
# ErrorDocument 500 /500.html
