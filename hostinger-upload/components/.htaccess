# ========================================
# COMPONENTS FOLDER SECURITY
# ========================================

# Disable directory browsing
Options -Indexes

# Allow access to HTML component files
<FilesMatch "\.(html|htm)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# Block access to sensitive files
<FilesMatch "^(\.htaccess|\.htpasswd|config|\.env|\.git|\.DS_Store)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block malicious requests
RewriteEngine On
RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteRule ^(.*)$ - [F,L]
