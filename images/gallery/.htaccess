# ========================================
# IMAGES FOLDER SECURITY
# ========================================

# Disable directory browsing
Options -Indexes

# Allow access to image files
<FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|bmp|tiff)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# Block access to sensitive files
<FilesMatch "^(\.htaccess|\.htpasswd|config|\.env|\.git|\.DS_Store|Thumbs\.db)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block malicious requests
RewriteEngine On
RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteRule ^(.*)$ - [F,L]

# Prevent execution of scripts in images folder
<FilesMatch "\.(php|pl|py|jsp|asp|sh|cgi)$">
    Order deny,allow
    Deny from all
</FilesMatch>
